# --- Azure Foundry (Azure OpenAI v1) ---
# Foundry resource endpoint. Either form works:
#   https://<resource>.openai.azure.com           (legacy form, SDK appends /openai/v1)
#   https://<resource>.openai.azure.com/openai/v1 (explicit v1 form)
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=<your-deployment-name>

# Optional. Leave empty to authenticate via Entra ID (recommended; required when
# API key auth is disabled on the resource). Run `az login` once, the backend
# will use DefaultAzureCredential.
AZURE_OPENAI_API_KEY=

# Optional. Only used by the legacy AsyncAzureOpenAI path; ignored when calling
# the v1 endpoint directly.
AZURE_OPENAI_API_VERSION=2024-10-21

# --- Authentication mode (optional) ---
# Each service picks "api_key" or "entra". Leave everything unset to
# auto-detect: a service uses its key when one is configured, else Entra ID.
# Force a mode globally with AUTH_MODE, or per-service with the overrides:
#   AUTH_MODE=api_key            # or: entra
#   AZURE_OPENAI_AUTH_MODE=entra # overrides AUTH_MODE for Foundry
#   AZURE_SPEECH_AUTH_MODE=api_key
# AUTH_MODE=

# --- Azure Speech ---
# Region of your Speech / Foundry resource (e.g. eastus2).
AZURE_SPEECH_REGION=eastus2
# API-key mode: set the resource key. The backend exchanges it for a
# short-lived token (regional STS endpoint); the key never reaches the browser.
AZURE_SPEECH_KEY=
# Entra mode: set the ARM resource ID instead (used to build the aad# token).
# AZURE_SPEECH_RESOURCE_ID=/subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.CognitiveServices/accounts/<name>

# --- Microsoft Learn MCP ---
# Public streamable-HTTP MCP server, no auth required. Always enabled.
MCP_LEARN_URL=https://learn.microsoft.com/api/mcp

# --- Additional answer sources (optional) ---
# Extra streamable-HTTP MCP servers to search alongside Microsoft Learn.
# Comma-separated list of entries; each entry is either `url` or `Name|url`.
# Results from all sources are merged (deduped + round-robin interleaved).
# Example:
# MCP_SERVERS=GitHub Docs|https://example.com/mcp, https://internal-wiki/mcp

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:5173
