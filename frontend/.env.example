# --- Frontend Environment Variables ---

# WebSocket URL override (optional).
# Leave unset for local development — Vite proxy handles routing to the backend.
# Set only for production or when the backend is on a different host.
# VITE_WS_URL=wss://api.example.com/ws

# Backend port for Vite proxy (optional, default: 8000).
# Must match the port used by `uvicorn main:app --port <PORT>`.
# BACKEND_PORT=8000
