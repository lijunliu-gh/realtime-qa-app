# --- Dev Tunnel & Teams App ---
# Used by start-tunnel.ps1/sh and generate_package.py

# Named dev tunnel (run `devtunnel create <name>` first)
TUNNEL_NAME=realtimeqa

# Dev tunnel domain (shown by `devtunnel show <name>`)
TEAMS_DOMAIN=xxxxxx-5173.jpe1.devtunnels.ms

# Entra App Registration ID (UUID)
TEAMS_APP_ID=00000000-0000-0000-0000-000000000000
